APP_NAME=Customer Churn Prediction API

APP_VERSION=1.0.0

API_PREFIX=/api/v1

API_BASE_URL=http://127.0.0.1:8000

DEBUG=False

HOST=0.0.0.0

PORT=8000

LOG_LEVEL=INFO

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

APP_DESCRIPTION=Production-ready FastAPI service for Customer Churn Prediction.

API_CONTACT_NAME=Raghvendra Bhalla

API_CONTACT_EMAIL=bhalla.services@gmail.com

API_LICENSE_NAME=MIT

MYSQL_ROOT_PASSWORD=rootpassword

MYSQL_DATABASE=mlflow

MYSQL_USER=mlflow

MYSQL_PASSWORD=mlflow

# Internal container port
MYSQL_PORT=3306

# Host port (optional, for local tools)
MYSQL_HOST_PORT=3307

# =============================================================================
# MLflow
# =============================================================================
MLFLOW_PORT=5000
MLFLOW_BACKEND_STORE_URI=mysql+pymysql://mlflow:mlflow@mysql:3306/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts